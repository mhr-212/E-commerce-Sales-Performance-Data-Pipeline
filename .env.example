# ============================================================
# Environment variables — copy to .env and fill in secrets
# NEVER commit .env to version control
# ============================================================

# PostgreSQL connection for the ETL pipeline
DATABASE_URL=postgresql://pipeline:pipeline@localhost:5432/ecommerce_dw

# PostgreSQL connection for Airflow metadata database
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow

# Airflow Fernet key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
AIRFLOW__CORE__FERNET_KEY=REPLACE_WITH_GENERATED_KEY

# Airflow webserver secret key
AIRFLOW__WEBSERVER__SECRET_KEY=REPLACE_WITH_RANDOM_STRING

# Path to raw CSV data (relative to project root inside container)
SALES_DATA_DIR=data/raw

# Alert email for pipeline failures
PIPELINE_ALERT_EMAIL=data-alerts@example.com
